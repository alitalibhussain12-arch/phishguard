# ═══════════════════════════════════════════════════════════════
# PhishGuard AI — Environment Configuration Example
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# Flask secret key — CHANGE THIS in production (use: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Flask environment: production | development
FLASK_ENV=production
FLASK_DEBUG=false

# Server port
PORT=5000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
